---
import BaseLayout from '../layouts/BaseLayout.astro';
import AuthForm from '../components/AuthForm.tsx';
---

<BaseLayout title="Crear cuenta — GymFlow AI">
  <main class="relative mx-auto flex min-h-dvh max-w-md flex-col justify-center px-6 py-10 overflow-hidden">
    <div class="absolute -right-20 top-20 -z-10 h-72 w-72 rounded-full bg-brand-500/10 blur-3xl"></div>
    <a href="/" class="mb-6 inline-flex text-sm font-semibold text-slate-400 hover:text-white transition-colors">← Volver</a>
    <h1 class="font-headline mb-1 text-3xl font-bold text-white">Crea tu cuenta</h1>
    <p class="mb-8 text-sm text-slate-400 font-medium">Un par de datos y empezamos.</p>
    <AuthForm mode="register" client:load />
  </main>
</BaseLayout>
