---
import AdminLayout from '../../layouts/AdminLayout.astro';
import AdminReservations from '../../components/AdminReservations.tsx';
---

<AdminLayout title="Reservas — Administración GymFlow">
  <div class="grid gap-6">
    <header class="flex flex-wrap items-center justify-between gap-3">
      <div>
        <h1 class="text-2xl font-bold text-slate-950">Todas las reservas</h1>
        <p class="mt-1 text-sm/6 text-slate-600">Filtra y diagnostica los intentos de reserva.</p>
      </div>
      <a href="/admin" class="font-semibold text-brand-700">Volver al panel</a>
    </header>
    <AdminReservations client:load />
  </div>
</AdminLayout>
