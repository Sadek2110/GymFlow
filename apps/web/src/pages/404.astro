---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Página no encontrada — GymFlow AI">
  <main class="mx-auto flex min-h-dvh max-w-md flex-col items-center justify-center gap-4 px-6 text-center">
    <p class="text-6xl font-black text-brand-500">404</p>
    <h1 class="text-2xl font-bold text-slate-900">Aquí no hay nada que entrenar</h1>
    <p class="text-slate-500">La página que buscas no existe o se movió de sitio.</p>
    <a
      href="/dashboard"
      class="mt-2 rounded-xl bg-brand-500 px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-brand-600"
    >
      Volver al inicio
    </a>
  </main>
</BaseLayout>
