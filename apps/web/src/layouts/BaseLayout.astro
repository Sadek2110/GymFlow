---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'GymFlow AI', description = 'Tu gimnasio, ordenado.' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#2f7fff" />
    <title>{title}</title>
  </head>
  <body class="min-h-dvh">
    <slot />
  </body>
</html>
