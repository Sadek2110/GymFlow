---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Admin — GymFlow AI' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <script is:inline>
      if (!localStorage.getItem('gymflow.accessToken')) {
        window.location.replace('/login');
      }
    </script>
  </head>
  <body class="min-h-dvh bg-slate-100">
    <main class="mx-auto max-w-5xl px-4 py-8">
      <slot />
    </main>
  </body>
</html>
