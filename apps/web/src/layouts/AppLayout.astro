---
import '../styles/global.css';
import BottomNav from '../components/BottomNav.astro';

interface Props {
  title?: string;
  active?: string;
}

const { title = 'GymFlow AI', active } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#050505" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Montserrat:wght@400;600;700;800;900&display=swap" rel="stylesheet">
    <title>{title}</title>
    <!-- Guard cliente: sin sesión, fuera. (Los tokens viven en localStorage; el SSR no los ve.) -->
    <script is:inline>
      if (!localStorage.getItem('gymflow.accessToken')) {
        window.location.replace('/login');
      }
    </script>
  </head>
  <body class="min-h-dvh pb-24 bg-dark-bg text-slate-100 antialiased">
    <main class="mx-auto max-w-md px-5 py-6">
      <slot />
    </main>
    <BottomNav active={active} />
  </body>
</html>
