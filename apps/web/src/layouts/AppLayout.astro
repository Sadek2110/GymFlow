---
import '../styles/global.css';
import BottomNav from '../components/BottomNav.astro';

interface Props {
  title?: string;
  active?: string;
}

const { title = 'GymFlow AI', active } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#2f7fff" />
    <title>{title}</title>
    <!-- Guard cliente: sin sesión, fuera. (Los tokens viven en localStorage; el SSR no los ve.) -->
    <script is:inline>
      if (!localStorage.getItem('gymflow.accessToken')) {
        window.location.replace('/login');
      }
    </script>
  </head>
  <body class="min-h-dvh pb-24">
    <main class="mx-auto max-w-md px-5 py-6">
      <slot />
    </main>
    <BottomNav active={active} />
  </body>
</html>
