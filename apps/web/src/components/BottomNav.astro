---
interface Props { active?: string }
const { active } = Astro.props;

const items = [
  { key: 'dashboard', href: '/dashboard', label: 'Inicio' },
  { key: 'routines', href: '/routines', label: 'Rutinas' },
  { key: 'train', href: '/train', label: 'Entrenar', center: true },
  { key: 'exercises', href: '/exercises', label: 'Ejercicios' },
  { key: 'profile', href: '/profile', label: 'Perfil' },
];
---

<nav
  class="fixed inset-x-0 bottom-0 z-50 border-t border-slate-200 bg-white/95 backdrop-blur"
  aria-label="Navegación principal"
>
  <ul class="mx-auto flex max-w-md items-center justify-around px-2 py-1.5">
    {items.map((item) => (
      <li>
        {item.center ? (
          <a
            href={item.href}
            class="grid h-14 w-14 -translate-y-3 place-items-center rounded-full bg-brand-500 text-xs font-bold text-white shadow-lg shadow-brand-500/30 transition-colors hover:bg-brand-600"
            aria-current={active === item.key ? 'page' : undefined}
          >
            {item.label}
          </a>
        ) : (
          <a
            href={item.href}
            class:list={[
              'touch-target grid place-items-center rounded-lg px-3 py-1.5 text-xs font-medium transition-colors',
              active === item.key ? 'text-brand-600' : 'text-slate-500 hover:text-slate-800',
            ]}
            aria-current={active === item.key ? 'page' : undefined}
          >
            {item.label}
          </a>
        )}
      </li>
    ))}
  </ul>
</nav>
