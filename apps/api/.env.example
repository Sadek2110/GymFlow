# Copia este archivo a apps/api/.env y ajusta los valores.
# NUNCA subas .env al repositorio.

# Base de datos (dev local: la DB corre en Docker en localhost:5432)
DATABASE_URL=postgresql://gymflow:password@localhost:5432/gymflow

# JWT — usa claves largas y aleatorias (mínimo 16 chars; recomendado 32+)
JWT_SECRET=cambia_esto_por_una_clave_larga_aleatoria_de_32_o_mas
JWT_REFRESH_SECRET=otra_clave_larga_aleatoria_distinta_de_32_o_mas
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

PORT=4000
CORS_ORIGIN=http://localhost:3000

# Módulo reservas (opcional, mono-usuario) — Fase 6
RESERVAGYM_ENABLED=false
RESERVAGYM_URL=https://gym-api.tudominio.com
RESERVAGYM_API_KEY=el_bearer_de_reservagym

# Seed (opcional): credenciales del admin que crea `prisma db seed`.
# Si se omiten, usa admin@gymflow.local / ChangeMe123!
ADMIN_EMAIL=admin@gymflow.local
ADMIN_PASSWORD=ChangeMe123!
